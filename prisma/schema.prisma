// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  name      String?
  role      String     @default("gym_owner") // gym_owner, member
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  members   Member[]
  workouts  Workout[]
  sessions  Session[]

  @@map("users")
}

model Member {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String
  gymOwnerId String
  gymOwner  User       @relation(fields: [gymOwnerId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  workouts  Workout[]

  @@map("members")
}

model Workout {
  id        String        @id @default(cuid())
  memberId  String
  member    Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime      @default(now())
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Relations
  items     WorkoutItem[]

  @@map("workouts")
}

model WorkoutItem {
  id           String   @id @default(cuid())
  workoutId    String
  workout      Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exerciseName String
  sets         Int
  reps         Int
  weight       Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("workout_items")
}

model Session {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime   @default(now())

  @@map("sessions")
}
